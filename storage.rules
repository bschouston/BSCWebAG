rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    // Public assets for event landing pages (cover + gallery)
    match /events/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /event-photos/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Registration photos should not be public
    match /registration-photos/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // Default deny for any other path
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
