rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "ADMIN" ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "SUPER_ADMIN");
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Events Collection
    match /events/{eventId} {
      allow read: if true; // Public can read events (filter by isPublic=true in query, but rules allow access)
      allow write: if isAdmin();
    }

    // Event RSVPs
    match /event_rsvps/{rsvpId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // News Collection
    match /news/{articleId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Token Transactions (Critical)
    match /token_transactions/{txId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      // Only Admins (or backend functions) should write transactions directly
      allow write: if isAdmin(); 
      // NOTE: In a real app, token logic should be backend-only to prevent fraud.
    }

    // Tournaments: public read-only access to live data so the public Live
    // page and the tracker tablets can subscribe with onSnapshot.
    // All writes happen server-side through API routes (Admin SDK).
    // Note: older tournament docs may lack publicLiveEnabled entirely, and
    // accessing a missing field in rules throws (=> deny), so check `in` first.
    function tournamentIsLive(tournamentId) {
      let t = get(/databases/$(database)/documents/tournaments/$(tournamentId)).data;
      return t.status == "ACTIVE" &&
        (!("publicLiveEnabled" in t) || t.publicLiveEnabled != false);
    }

    // Admins also get realtime client reads (e.g. live scores in the admin
    // schedule), including DRAFT tournaments.
    function canReadTournament(tournamentId) {
      return tournamentIsLive(tournamentId) || isAdmin();
    }

    match /tournaments/{tournamentId} {
      allow read: if isAdmin() ||
        (resource.data.status == "ACTIVE" &&
          (!("publicLiveEnabled" in resource.data) || resource.data.publicLiveEnabled != false));
      allow write: if false;

      match /matches/{matchId} {
        allow read: if canReadTournament(tournamentId);
        allow write: if false;

        // Play-by-play history (powers tracker history + live transparency).
        match /plays/{playId} {
          allow read: if canReadTournament(tournamentId);
          allow write: if false;
        }
      }

      match /teams/{teamId} {
        allow read: if canReadTournament(tournamentId);
        allow write: if false;
      }

      match /divisions/{divisionId} {
        allow read: if canReadTournament(tournamentId);
        allow write: if false;
      }

      match /players/{playerId} {
        allow read: if canReadTournament(tournamentId);
        allow write: if false;
      }

      match /playerStats/{playerId} {
        allow read: if canReadTournament(tournamentId);
        allow write: if false;
      }

      match /teamStats/{teamId} {
        allow read: if canReadTournament(tournamentId);
        allow write: if false;
      }

      // Locks and PII mirrors stay server-only.
      match /locks/{lockId} {
        allow read, write: if false;
      }
      match /playersPrivate/{playerId} {
        allow read, write: if false;
      }
    }

    // Global per-sport tracker config (stats, colors, layout, set rules).
    // Public read: the capture UI and web leaderboards subscribe directly.
    // All writes go through server API routes (Admin SDK).
    match /trackerConfigs/{sport} {
      allow read: if true;
      allow write: if false;

      // Passcode hash lives here; never readable from any client.
      match /private/{docId} {
        allow read, write: if false;
      }
    }

    // Registered sport trackers (created in tracker app). Server writes only.
    match /sportTrackers/{trackerId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
